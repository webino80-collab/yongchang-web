VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 문의 알림: Supabase Edge Function `send-contact-mail` Secrets (브라우저 .env 아님)
# 권장: Cloudflare Workers transactional-mail (send_email) — register-mail 등과 동일
# MAIL_WORKER_URL=https://yongchang-transactional-mail.<계정>.workers.dev
# MAIL_WORKER_KEY=Supabase Edge Secrets용 Bearer 토큰 (Cloudflare Worker의 MAIL_WORKER_SECRET 과 동일 값 권장)
# (구명칭 MAIL_WORKER_SECRET 도 Edge 코드에서 호환 읽기)
# SUPABASE_SERVICE_ROLE_KEY= (Edge에서 INSERT 직후 행 검증용, 프로젝트 서비스 롤 키)
# ADMIN_EMAIL=ycpbm@hanmail.net
#
# (선택) MAIL_WORKER 미설정 시 SMTP 폴백 — 다음(Daum) 예시
# SMTP_HOST=smtp.daum.net
# SMTP_PORT=465
# SMTP_STARTTLS=0
# SMTP_USER=계정@daum.net
# SMTP_PASS=****
# SMTP_FROM=no-reply@yongchang.co.kr
# SITE_NAME=(주)용창
#
# contact_inquiries INSERT Database Webhook으로 이 함수를 쓰는 경우,
# 프론트에서도 invoke 하므로 메일이 중복됩니다. 웹훅을 끄거나 invoke만 사용하세요.
#
# 문의 답변 메일: Edge `send-inquiry-reply` — MAIL_WORKER_URL·MAIL_WORKER_KEY 또는 SMTP (send-contact-mail 과 동일 Secret 권장)
#
# 프로젝트 비활성 완화: Edge Function `keep-alive` 배포 후, 외부 크론에서 주기적으로 GET
#   https://YOUR_PROJECT_ID.supabase.co/functions/v1/keep-alive
# (예: cron-job.org 6~12시간마다 — URL은 비공개 유지)

# 선택: 문의 페이지 Google 지도 임베드가 비어 보일 때 — Google Cloud에서 Maps Embed API 키 발급 후 설정
# VITE_GOOGLE_MAPS_EMBED_API_KEY=
