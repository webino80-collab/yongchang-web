VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 문의 메일: Supabase Edge Function `send-contact-mail` Secrets (브라우저 .env 아님)
# 다음(Daum) SMTP 예시 — 대시보드에서 IMAP/SMTP 사용 허용·앱 비밀번호 등 계정 설정 필요
# SMTP_HOST=smtp.daum.net
# SMTP_PORT=465
# SMTP_STARTTLS=0
# SMTP_USER=계정@daum.net
# SMTP_PASS=****
# SMTP_FROM=no-reply@yongchang.co.kr
# ADMIN_EMAIL=ycpbm@hanmail.net
# SITE_NAME=(주)용창
#
# (선택) SMTP 대신 Cloudflare Worker 발송 시에만:
# CF_CONTACT_MAIL_WORKER_URL=...
# CF_CONTACT_MAIL_SECRET=...

# 선택: 문의 페이지 Google 지도 임베드가 비어 보일 때 — Google Cloud에서 Maps Embed API 키 발급 후 설정
# VITE_GOOGLE_MAPS_EMBED_API_KEY=
